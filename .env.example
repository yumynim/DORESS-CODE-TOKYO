# =========================================================
# DRESS CODE TOKYO — 環境変数（Vercel の Project Settings → Environment Variables に設定）
# ---------------------------------------------------------
# このファイル自体はコミットしてOK（値は空のテンプレート）。
# 実際の値は絶対にこのファイルに書かず、Vercelの管理画面にだけ入力すること。
# =========================================================

# ---- Square ----
# 'sandbox' でテスト、本番稼働の直前に 'production' へ切り替える。
# 切り替えたら ACCESS_TOKEN / LOCATION_ID / WEBHOOK_SIGNATURE_KEY も本番用に全部差し替えること
# （Sandbox用とProduction用は別物。混ぜるとバグの元）。
SQUARE_ENVIRONMENT=sandbox

# Square Developer Dashboard（developer.squareup.com/apps）→ 作成したアプリ →
# Sandbox / Production それぞれの "Access Token"
SQUARE_ACCESS_TOKEN=

# Square Dashboard →「決済」→「場所（Locations）」で確認できる Location ID
SQUARE_LOCATION_ID=

# Square Developer Dashboard → Webhooks → Subscription作成時に発行される Signature Key
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Webhookの通知先URL（署名検証の計算に使う。実際にVercelへデプロイした後のURLを設定）
# 例: https://dresscode-tokyo.vercel.app/api/square-webhook
SQUARE_WEBHOOK_URL=

# ---- Supabase ----
# js/auth-config.js（ブラウザ用）と同じ Project URL / anon key。
# ここではサーバー側で「誰がログイン中か」を確認するためだけに使う（弱い権限でOK）。
SUPABASE_URL=
SUPABASE_ANON_KEY=

# こちらは強い権限（RLSを無視できる）。絶対にブラウザ側のコードに書かないこと。
# Supabase Dashboard → Project Settings → API → "service_role" キー
SUPABASE_SERVICE_ROLE_KEY=
